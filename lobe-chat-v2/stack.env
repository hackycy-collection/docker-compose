# Proxy，如果你需要的话（比如你使用 GitHub 作为鉴权服务提供商）
# HTTP_PROXY=http://localhost:7890
# HTTPS_PROXY=http://localhost:7890

# 允许登录的邮箱地址，用英文逗号分隔
# 设置后只有列表中的邮箱可以登录，其他用户可以注册但无法登录
# 留空则允许所有用户注册登录
# AUTH_ALLOWED_EMAILS=user1@example.com,user2@example.com

# 禁用用户注册（仅允许 SSO 登录）
# 设置为 1 后，用户无法通过邮箱密码注册，只能通过 SSO 登录
# AUTH_DISABLE_EMAIL_PASSWORD=1

# ===================
# ===== 预设配置 =====
# ===================
# 如没有特殊需要不用更改
LOBE_PORT=3210
RUSTFS_PORT=9000
APP_URL=http://ai.sooosin.com
INTERNAL_APP_URL=http://localhost:3210

# 密钥配置（由 setup.sh 自动生成）
KEY_VAULTS_SECRET=XFXJ0iAmJTms888LQzMQREdISY10S2nGpzASL3QzT3o=
AUTH_SECRET=I4MRl2dbin3yWn9KZ83TBHcOQX9rfXwvGvsiCP5DQ04=

# Postgres 相关，也即 DB 必须的环境变量
LOBE_DB_NAME=lobechat
POSTGRES_PASSWORD=uWNZugjBqixf8dxC

# RustFS S3 配置
RUSTFS_ACCESS_KEY=admin
RUSTFS_SECRET_KEY=C+BaOD0KOD37Q/K5tWoGeOK79SooTQGTGvMDmu4klF0=

# 在下方配置 rustfs 中添加的桶
S3_ENDPOINT=http://localhost:9000
RUSTFS_LOBE_BUCKET=lobe

