{
  "gateway": {
    "mode": "local",
    "controlUi": {
      "enabled": true,
      "basePath": "/",
      "dangerouslyAllowHostHeaderOriginFallback": true
    },
    "auth": {
      "mode": "token",
      "allowTailscale": true,
      "token": "your_token_here"
    },
    "remote": {
      "token": "your_token_here"
    }
  }
}